# ============================================================================
# Parvalon — environment template. Copy to .env and fill. NEVER commit .env.
# ============================================================================

# --- Networks ---------------------------------------------------------------
# Robinhood Chain testnet (primary, chainId 46630) — get an Alchemy/RPC URL.
ROBINHOOD_TESTNET_RPC_URL=
# Arbitrum Sepolia (fallback, chainId 421614).
ARBITRUM_SEPOLIA_RPC_URL=

# --- Deploy / contracts -----------------------------------------------------
# Deployer key. Use a dedicated, low-value testnet key. Prefer a keystore/HSM in prod.
PRIVATE_KEY=
# Governance (multisig in production). Defaults to the deployer if unset.
ADMIN_ADDRESS=
# Per-asset issuer (transfer-agent ops). Defaults to the deployer if unset.
ISSUER_ADDRESS=
# D3 action-source mode. Default is FALSE (fail-closed: every announcement needs an
# explicit attestation). Set true ONLY for a local/testnet demo — Deploy reverts if
# AUTO_ATTEST=true on any chain other than 31337 / 421614 / 46630.
AUTO_ATTEST=false
# Real token addresses on Robinhood Chain. Leave blank on Sepolia/local to deploy mocks.
USDG_ADDRESS=
TSLA_ADDRESS=
AMZN_ADDRESS=

# --- Verification (Blockscout / Arbiscan) -----------------------------------
ROBINHOOD_BLOCKSCOUT_API_URL=https://explorer.testnet.chain.robinhood.com/api
BLOCKSCOUT_API_KEY=
ARBISCAN_API_KEY=

# --- Snapshot CLI -----------------------------------------------------------
RPC_URL=

# --- Frontend (NEXT_PUBLIC_* are exposed to the browser) --------------------
NEXT_PUBLIC_CHAIN_ID=46630
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_DISTRIBUTOR_ADDRESS=
# Token addresses for the issuer console + symbol resolution (blank = use bundled local deployment).
NEXT_PUBLIC_USDG_ADDRESS=
NEXT_PUBLIC_TSLA_ADDRESS=
NEXT_PUBLIC_AMZN_ADDRESS=
NEXT_PUBLIC_BLOCKSCOUT_URL=https://explorer.testnet.chain.robinhood.com
# Optional WalletConnect (adds the WC connector when set).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Gasless claims (SHIPPED): a server-side relayer submits claims on behalf of holders.
# Trustless by design — claim-on-behalf always pays `account`, never the relayer.
NEXT_PUBLIC_GASLESS_ENABLED=false
RELAYER_PRIVATE_KEY=          # server-only; a funded key that pays gas for claims

# Passkey / smart-account onboarding (ROADMAP — Alchemy Account Kit + Gas Manager).
# Not yet wired into the build; reserved for the no-seed-phrase enhancement.
ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_GAS_POLICY_ID=
