# @parvalon/monitor — example environment. Copy to .env (gitignored) and edit.
# Precedence: CLI flags > these env vars > deployments/<chainId>.json > defaults.

# --- required -------------------------------------------------------------
# RPC endpoint. ws(s):// enables push events; http(s):// uses poll-based watch.
RPC_URL=http://127.0.0.1:8545
# Chain id (also keys the deployments/<chainId>.json address lookup).
CHAIN_ID=31337

# --- addresses (optional; resolved from deployments/<chainId>.json if unset) --
# REGISTRY_ADDRESS=0x...
# DISTRIBUTOR_ADDRESS=0x...
# DEPLOYMENTS_PATH=../../deployments/31337.json

# --- alerting -------------------------------------------------------------
# Webhook sink (PagerDuty Events v2 / Slack / Discord / Opsgenie). Unset = console only.
# ALERT_WEBHOOK_URL=https://events.pagerduty.com/v2/enqueue
# Minimum severity to emit: info | notify | page
MIN_SEVERITY=info
# Per-condition de-dup window (ms).
ALERT_COOLDOWN_MS=300000

# --- cadence --------------------------------------------------------------
# Solvency + pause sweep interval (ms).
POLL_INTERVAL_MS=30000

# --- anomaly thresholds (optional) ----------------------------------------
# Comma-separated expected issuer/funder allowlist; a Funded from outside alerts.
# EXPECTED_FUNDERS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
# MAX_RATE_PER_SHARE=1000000000000000000000000
# MAX_TOTAL_PAYOUT=1000000000000000000000000000000
# LARGE_FUNDING_RATIO=1.0
# MAX_CLAIM_REVERT_RATE=0.25
# MIN_CLAIM_ATTEMPTS=8
# LARGE_SWEEP_REMAINDER_RATIO=0.5
# EARLY_SWEEP_WINDOW_SECS=0
